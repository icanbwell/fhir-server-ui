{
    "name": "fhir-server-ui",
    "version": "1.0.0",
    "description": "UI to display FHIR resources in a web browser",
    "main": "src/index.ts",
    "scripts": {
        "build": "tsc && yarn copy-files",
        "build_react": "node src/scripts/build.js",
        "start_react": "node src/scripts/start.js",
        "build-clean": "yarn clean && tsc && yarn copy-files",
        "clean": "rm -rf ./dist",
        "start": "node dist/index.js",
        "dev": "nodemon",
        "watch": "npm-watch",
        "copy-files": "cp ./src/oauth/*.html ./dist/oauth/"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@babel/core": "^7.23.3",
        "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
        "@babel/plugin-syntax-flow": "^7.23.3",
        "@babel/plugin-transform-react-jsx": "^7.23.4",
        "@babel/preset-env": "^7.23.3",
        "@babel/preset-typescript": "^7.23.3",
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@fontsource/roboto": "^5.0.8",
        "@mui/icons-material": "^5.14.18",
        "@mui/material": "^5.14.18",
        "@mui/styles": "^5.14.18",
        "@mui/system": "^5.14.18",
        "@mui/x-date-pickers": "^6.18.1",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
        "@svgr/webpack": "^8.1.0",
        "@types/async": "^3.2.23",
        "@types/cookie-parser": "^1.4.6",
        "@types/express": "^4.17.21",
        "@types/express-useragent": "^1.0.5",
        "@types/fhir": "^0.0.40",
        "@types/jest": "^29.5.9",
        "@types/js-cookie": "^3.0.6",
        "@types/node": "^20.9.3",
        "@types/passport": "^1.0.16",
        "@types/passport-jwt": "^3.0.13",
        "@types/react": "^18.2.38",
        "@types/react-dom": "^18.2.16",
        "@types/superagent": "^4.1.22",
        "@types/supertest": "^2.0.16",
        "async": "^3.2.5",
        "axios": "^1.6.2",
        "babel-jest": "^29.7.0",
        "babel-loader": "^9.1.3",
        "babel-plugin-named-asset-import": "^0.3.8",
        "babel-preset-react-app": "^10.0.1",
        "bfj": "^8.0.0",
        "browserslist": "^4.22.1",
        "buffer": "^6.0.3",
        "camelcase": "^8.0.0",
        "case-sensitive-paths-webpack-plugin": "^2.4.0",
        "chart.js": "^4.4.0",
        "cookie-parser": "^1.4.6",
        "crypto": "^1.0.1",
        "css-loader": "^6.8.1",
        "css-minimizer-webpack-plugin": "^5.0.1",
        "dayjs": "^1.11.10",
        "dotenv": "^16.3.1",
        "dotenv-expand": "^10.0.0",
        "eslint": "^8.54.0",
        "eslint-config-react-app": "^7.0.1",
        "eslint-plugin-typescript": "^0.14.0",
        "eslint-webpack-plugin": "^4.0.1",
        "express": "^4.18.2",
        "express-http-context": "^1.2.4",
        "express-useragent": "^1.0.15",
        "file-loader": "^6.2.0",
        "fs-extra": "^11.1.1",
        "helmet": "^7.1.0",
        "html-webpack-plugin": "^5.5.3",
        "http-proxy-middleware": "^2.0.6",
        "identity-obj-proxy": "^3.0.0",
        "js-cookie": "^3.0.5",
        "jwks-rsa": "^3.1.0",
        "mini-css-extract-plugin": "^2.7.6",
        "mysql2": "^3.6.4",
        "openid-client": "^5.6.1",
        "passport": "^0.6.0",
        "passport-jwt": "^4.0.1",
        "postcss": "^8.4.31",
        "postcss-flexbugs-fixes": "^5.0.2",
        "postcss-loader": "^7.3.3",
        "postcss-normalize": "^10.0.1",
        "postcss-preset-env": "^9.3.0",
        "prompts": "^2.4.2",
        "react": "^18.2.0",
        "react-app-polyfill": "^3.0.0",
        "react-chartjs-2": "^5.2.0",
        "react-dev-utils": "^12.0.1",
        "react-dom": "^18.2.0",
        "react-icons": "^4.12.0",
        "react-refresh": "^0.14.0",
        "react-router-dom": "^6.19.0",
        "react-vertical-timeline-component": "^3.6.0",
        "resolve": "^1.22.8",
        "resolve-url-loader": "^5.0.0",
        "sass-loader": "^13.3.2",
        "semver": "^7.5.4",
        "source-map-loader": "^4.0.1",
        "style-loader": "^3.3.3",
        "superagent": "^8.1.2",
        "tailwindcss": "^3.3.5",
        "terser-webpack-plugin": "^5.3.9",
        "typescript": "^5.3.2",
        "var": "^0.4.0",
        "web-vitals": "^3.5.0",
        "webpack-dev-server": "^4.15.1",
        "webpack-manifest-plugin": "^5.0.0",
        "workbox-webpack-plugin": "^7.0.0"
    },
    "devDependencies": {
        "@testing-library/dom": "^9.3.3",
        "@testing-library/jest-dom": "^6.1.4",
        "@testing-library/react": "^14.1.2",
        "@testing-library/user-event": "^14.5.1",
        "@typescript-eslint/eslint-plugin": "^6.12.0",
        "@types/node": "^20.9.3",
        "cra-build-watch": "^3.4.0",
        "dotenv-cli": "^7.3.0",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-security": "^1.7.1",
        "jest": "^29.7.0",
        "jest-matcher-utils": "^29.7.0",
        "jest-resolve": "^29.7.0",
        "jest-watch-typeahead": "^2.2.2",
        "jose": "^5.1.1",
        "nock": "^13.3.8",
        "nodemon": "^3.0.1",
        "npm-check-updates": "^16.14.11",
        "npm-watch": "^0.11.0",
        "prettier": "^3.1.0",
        "supertest": "^6.3.3",
        "ts-node": "^10.9.1",
        "webpack": "^5.89.0"
    },
    "jest": {
        "watchman": false,
        "watchPathIgnorePatterns": [
            "globalConfig"
        ],
        "testEnvironment": "node",
        "testPathIgnorePatterns": [
            "<rootDir>/node_modules/",
            "<rootDir>/src/src"
        ],
        "setupFiles": [
            "<rootDir>/jest/setEnvVars.js",
            "react-app-polyfill/jsdom"
        ],
        "roots": [
            "<rootDir>/src/src"
        ],
        "collectCoverageFrom": [
            "src/**/*.{js,jsx,ts,tsx}",
            "!src/**/*.d.ts"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/src/src/setupTests.js"
        ],
        "testMatch": [
            "<rootDir>/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
            "<rootDir>/src/**/*.{spec,test}.{js,jsx,ts,tsx}"
        ],
        "transform": {
            "^.+\\.(js|jsx|mjs|cjs|ts|tsx)$": "<rootDir>/src/config/jest/babelTransform.js",
            "^.+\\.css$": "<rootDir>/src/config/jest/cssTransform.js",
            "^(?!.*\\.(js|jsx|mjs|cjs|ts|tsx|css|json)$)": "<rootDir>/src/config/jest/fileTransform.js"
        },
        "transformIgnorePatterns": [
            "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|mjs|cjs|ts|tsx)$",
            "^.+\\.module\\.(css|sass|scss)$"
        ],
        "modulePaths": [],
        "moduleNameMapper": {
            "^react-native$": "react-native-web",
            "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy"
        },
        "moduleFileExtensions": [
            "web.js",
            "js",
            "web.ts",
            "ts",
            "web.tsx",
            "tsx",
            "json",
            "web.jsx",
            "jsx",
            "node"
        ],
        "watchPlugins": [
            "jest-watch-typeahead/filename",
            "jest-watch-typeahead/testname"
        ],
        "resetMocks": true
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "tsconfig.json": "./tsconfig.json",
    "watch": {
        "build_react": {
            "patterns": [
                "./src/src"
            ],
            "extensions": "js,jsx,ts,tsx",
            "delay": 5000
        }
    }
}
