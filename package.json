{
  "name": "fhir-server-ui",
  "version": "1.0.0",
  "description": "UI to display FHIR resources in a web browser",
  "main": "src/index.tsx",
  "scripts": {
    "build": "node scripts/build.js",
    "build:prod": "DISABLE_ESLINT_PLUGIN='true' node scripts/build.js",
    "start": "NODE_ENV=dev node scripts/start.js",
    "lint": "NODE_ENV=test npm run test:lint",
    "test:lint": "NODE_OPTIONS=--max-old-space-size=8096 eslint \"src/**/*.tsx\" \"src/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/core": "^7.24.3",
    "@babel/plugin-transform-private-property-in-object": "^7.24.1",
    "@babel/plugin-syntax-flow": "^7.24.1",
    "@babel/plugin-transform-react-jsx": "^7.23.4",
    "@babel/preset-env": "^7.24.3",
    "@babel/preset-typescript": "^7.24.1",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@fontsource/roboto": "^5.0.12",
    "@mui/icons-material": "^5.15.14",
    "@mui/material": "^5.15.14",
    "@mui/styles": "^5.15.14",
    "@mui/system": "^5.15.14",
    "@mui/x-date-pickers": "^7.1.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
    "@sentry/react": "7.109.0",
    "@sentry/webpack-plugin": "2.16.0",
    "@svgr/webpack": "^8.1.0",
    "axios": "^1.6.8",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "babel-plugin-named-asset-import": "^0.3.8",
    "babel-preset-react-app": "^10.0.1",
    "bfj": "^8.0.0",
    "browserslist": "^4.23.0",
    "buffer": "^6.0.3",
    "camelcase": "^8.0.0",
    "case-sensitive-paths-webpack-plugin": "^2.4.0",
    "chart.js": "^4.4.2",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.5",
    "dotenv-expand": "^11.0.6",
    "file-loader": "^6.2.0",
    "fs-extra": "^11.2.0",
    "html-webpack-plugin": "^5.6.0",
    "jwt-decode": "^4.0.0",
    "mini-css-extract-plugin": "^2.8.1",
    "postcss": "^8.4.38",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-loader": "^8.1.1",
    "postcss-normalize": "^10.0.1",
    "postcss-preset-env": "^9.5.2",
    "react": "^18.2.0",
    "react-app-polyfill": "^3.0.0",
    "react-chartjs-2": "^5.2.0",
    "react-dev-utils": "^12.0.1",
    "react-dom": "^18.2.0",
    "react-icons": "^5.0.1",
    "react-refresh": "^0.14.0",
    "react-router-dom": "^6.22.3",
    "react-vertical-timeline-component": "^3.6.0",
    "resolve": "^1.22.8",
    "resolve-url-loader": "^5.0.0",
    "sass-loader": "^14.1.1",
    "semver": "^7.6.0",
    "source-map-loader": "^5.0.0",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.3",
    "terser-webpack-plugin": "^5.3.10",
    "typescript": "^5.4.3",
    "uuid": "^9.0.1",
    "var": "^0.4.0",
    "web-vitals": "^3.5.2",
    "webpack-dev-server": "^5.0.4",
    "webpack-manifest-plugin": "^5.0.0",
    "workbox-webpack-plugin": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.2",
    "@testing-library/user-event": "^14.5.2",
    "@typescript-eslint/parser": "^7.4.0",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "@types/react-vertical-timeline-component": "^3.3.6",
    "@types/uuid": "^9.0.8",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-config-react-app": "^7.0.1",
    "eslint-webpack-plugin": "^4.1.0",
    "eslint-plugin-security": "^2.1.1",
    "jest": "^29.7.0",
    "jest-matcher-utils": "^29.7.0",
    "jest-resolve": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "nock": "^13.5.4",
    "nodemon": "^3.1.0",
    "npm-check-updates": "^16.14.18",
    "pre-commit": "^1.2.2",
    "prettier": "^3.2.5",
    "webpack": "^5.91.0"
  },
  "pre-commit": [
    "lint"
  ],
  "jest": {
    "watchman": false,
    "watchPathIgnorePatterns": [
      "globalConfig"
    ],
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/src/"
    ],
    "setupFiles": [
      "<rootDir>/jest/setEnvVars.js",
      "react-app-polyfill/jsdom"
    ],
    "roots": [
      "<rootDir>/src/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.js"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
      "<rootDir>/src/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "transform": {
      "^.+\\.(js|jsx|mjs|cjs|ts|tsx)$": "<rootDir>/src/config/jest/babelTransform.js",
      "^.+\\.css$": "<rootDir>/src/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|mjs|cjs|ts|tsx|css|json)$)": "<rootDir>/src/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|mjs|cjs|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ],
    "modulePaths": [],
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ],
    "resetMocks": true
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "tsconfig.json": "./tsconfig.json"
}
